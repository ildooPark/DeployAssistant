             Link="Model/ProjectFile.cs" />
    <Compile Include="../DeployAssistant.Core/Model/ProjectIgnoreData.cs"
             Link="Model/ProjectIgnoreData.cs" />
    <Compile Include="../DeployAssistant.Core/Model/ProjectMetaData.cs"
             Link="Model/ProjectMetaData.cs" />
