             Link="Interfaces/IProjectData.cs" />

    <!-- Model -->
    <Compile Include="../DeployAssistant.Core/Model/ChangedFile.cs"
             Link="Model/ChangedFile.cs" />
    <Compile Include="../DeployAssistant.Core/Model/DeployData.cs"
             Link="Model/DeployData.cs" />
    <Compile Include="../DeployAssistant.Core/Model/LocalConfigData.cs"
             Link="Model/LocalConfigData.cs" />
    <Compile Include="../DeployAssistant.Core/Model/ProjectData.cs"
             Link="Model/ProjectData.cs" />
