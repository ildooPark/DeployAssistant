<Project Sdk="Microsoft.NET.Sdk">

  <PropertyGroup>
    <TargetFramework>netstandard2.0</TargetFramework>
    <Nullable>enable</Nullable>
    <LangVersion>latest</LangVersion>
    <ImplicitUsings>enable</ImplicitUsings>
    <AssemblyName>DeployAssistant.Core.Standard</AssemblyName>
    <RootNamespace>DeployAssistant</RootNamespace>
  </PropertyGroup>

  <ItemGroup>
    <PackageReference Include="DocumentFormat.OpenXml" Version="3.0.2" />
    <PackageReference Include="System.IO.Packaging" Version="8.0.1" />
    <PackageReference Include="System.Text.Json" Version="8.0.5" />
  </ItemGroup>

  <!-- Link unchanged source files directly from DeployAssistant.Core -->
  <ItemGroup>
    <!-- Interfaces -->
    <Compile Include="../DeployAssistant.Core/Interfaces/IManager.cs"
             Link="Interfaces/IManager.cs" />
