<Window x:Class="DeployAssistant.View.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:DeployAssistant.View"
        xmlns:avalonDock="clr-namespace:AvalonDock;assembly=AvalonDock"
        xmlns:avalonDockLayout="clr-namespace:AvalonDock.Layout;assembly=AvalonDock"
        xmlns:avalonTheme="clr-namespace:AvalonDock.Themes;assembly=AvalonDock.Themes.VS2013"
        mc:Ignorable="d"
        Title="Deploy Assistant" Height="900" Width="1600"
        MinHeight="700"
        MinWidth="1100"
        Closing="Window_Closing"
        Loaded="Window_Loaded">

    <Window.Resources>
        <!-- StateBadgeStyle — uses MetaDataVM.CurrentMetaDataState binding unique to MainWindow -->
        <Style x:Key="StateBadgeStyle" TargetType="Border">
            <Setter Property="Background" Value="#757575"/>
            <Style.Triggers>
                <DataTrigger Binding="{Binding MetaDataVM.CurrentMetaDataState}" Value="Processing">
                    <Setter Property="Background" Value="#1976D2"/>
                </DataTrigger>
                <DataTrigger Binding="{Binding MetaDataVM.CurrentMetaDataState}" Value="Initializing">
                    <Setter Property="Background" Value="#1976D2"/>
                </DataTrigger>
                <DataTrigger Binding="{Binding MetaDataVM.CurrentMetaDataState}" Value="Updating">
                    <Setter Property="Background" Value="#1976D2"/>
                </DataTrigger>
                <DataTrigger Binding="{Binding MetaDataVM.CurrentMetaDataState}" Value="Retrieving">
                    <Setter Property="Background" Value="#1976D2"/>
                </DataTrigger>
                <DataTrigger Binding="{Binding MetaDataVM.CurrentMetaDataState}" Value="Reverting">
                    <Setter Property="Background" Value="#F57C00"/>
                </DataTrigger>
                <DataTrigger Binding="{Binding MetaDataVM.CurrentMetaDataState}" Value="Exporting">
                    <Setter Property="Background" Value="#7B1FA2"/>
                </DataTrigger>
                <DataTrigger Binding="{Binding MetaDataVM.CurrentMetaDataState}" Value="IntegrityChecking">
                    <Setter Property="Background" Value="#0097A7"/>
                </DataTrigger>
                <DataTrigger Binding="{Binding MetaDataVM.CurrentMetaDataState}" Value="Idle">
                    <Setter Property="Background" Value="#388E3C"/>
                </DataTrigger>
            </Style.Triggers>
        </Style>
    </Window.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- ═══════════════════════════════════════════════════════
             Header ToolBar
        ════════════════════════════════════════════════════════════ -->
        <Border Grid.Row="0" Background="#2D2D2D" Padding="6,4">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <!-- Primary action buttons -->
                <StackPanel Grid.Column="0" Orientation="Horizontal">
                    <Button x:Name="SetDeploySrcDir"
                            Margin="4,2"
                            Padding="10,5"
                            FontSize="13"
                            Content="Set Source Dir"
                            Command="{Binding FileTrackVM.GetDeploySrcDir}"
                            Style="{StaticResource ToolbarButtonStyle}"/>
                    <Button x:Name="SetProject"
                            Margin="4,2"
                            Padding="10,5"
                            FontSize="13"
                            Content="Set Dest Dir"
                            Command="{Binding MetaDataVM.GetProject}"
                            Style="{StaticResource ToolbarButtonStyle}"/>
                    <Button x:Name="IntegrityCheckButton"
                            Margin="4,2"
                            Padding="10,5"
                            FontSize="13"
                            Content="Integrity Check"
                            Command="{Binding FileTrackVM.CheckProjectIntegrity}"
                            Style="{StaticResource ToolbarButtonStyle}"/>
                </StackPanel>

                <!-- Project info -->
                <StackPanel Grid.Column="1" Orientation="Horizontal"
                            VerticalAlignment="Center" Margin="16,0">
                    <TextBlock VerticalAlignment="Center" Foreground="#BBBBBB" FontSize="13">
                        <Run Text="Project: "/>
                        <Run Text="{Binding MetaDataVM.ProjectName}" FontWeight="Bold" Foreground="White"/>
                    </TextBlock>
                    <TextBlock Margin="20,0,0,0" VerticalAlignment="Center" Foreground="#BBBBBB" FontSize="13">
                        <Run Text="Version: "/>
                        <Run Text="{Binding MetaDataVM.CurrentVersion}" FontWeight="Bold" Foreground="#4EC9B0"/>
                    </TextBlock>
                </StackPanel>

                <!-- State badge -->
                <Border Grid.Column="2" CornerRadius="4" Padding="8,3"
                        VerticalAlignment="Center" Margin="4,0"
                        Style="{StaticResource StateBadgeStyle}">
                    <TextBlock Text="{Binding MetaDataVM.CurrentMetaDataState}"
                               FontSize="12" Foreground="White" FontWeight="SemiBold"/>
                </Border>
            </Grid>
        </Border>

        <!-- ═══════════════════════════════════════════════════════
             AvalonDock DockingManager
        ════════════════════════════════════════════════════════════ -->
        <avalonDock:DockingManager Grid.Row="1"
                                   x:Name="DockManager"
                                   AllowMixedOrientation="True">
            <avalonDock:DockingManager.Theme>
                <avalonTheme:Vs2013LightTheme/>
            </avalonDock:DockingManager.Theme>
            <avalonDockLayout:LayoutRoot>
                <avalonDockLayout:LayoutPanel Orientation="Horizontal">

                    <!-- LEFT: History pane (top) + DiffLog pane (bottom) -->
                    <avalonDockLayout:LayoutAnchorablePaneGroup Orientation="Vertical"
                                                         DockWidth="360">

                        <!-- Version History -->
                        <avalonDockLayout:LayoutAnchorablePane DockHeight="0.45*">
                            <avalonDockLayout:LayoutAnchorable Title="Version History"
                                                         ContentId="HistoryPanel"
                                                         CanClose="False"
                                                         CanHide="False">
                                <ListView x:Name="backupList"
                                          ItemsSource="{Binding BackupVM.BackupProjectDataList}"
                                          SelectedItem="{Binding BackupVM.SelectedItem}"
                                          Tag="{Binding RelativeSource={RelativeSource AncestorType=Window}, Path=DataContext}"
                                          BorderBrush="#CDCDCD"
                                          ScrollViewer.CanContentScroll="True"
                                          ScrollViewer.VerticalScrollBarVisibility="Auto"
                                          ScrollViewer.HorizontalScrollBarVisibility="Auto">
                                    <ListView.View>
                                        <GridView>
                                            <GridViewColumn Header="Rev"     DisplayMemberBinding="{Binding RevisionNumber}"                                  Width="35"/>
                                            <GridViewColumn Header="Version" DisplayMemberBinding="{Binding UpdatedVersion}"                                  Width="140"/>
                                            <GridViewColumn Header="Date"    DisplayMemberBinding="{Binding UpdatedTime, StringFormat={}{0:yyyy-MM-dd}}"      Width="85"/>
                                            <GridViewColumn Header="By"      DisplayMemberBinding="{Binding UpdaterName}"                                     Width="55"/>
                                            <GridViewColumn Header="Δ"       DisplayMemberBinding="{Binding NumberOfChanges}"                                 Width="28"/>
                                        </GridView>
                                    </ListView.View>
                                    <ListView.ItemContainerStyle>
                                        <Style TargetType="ListViewItem">
                                            <Setter Property="Background" Value="Transparent"/>
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding IsProjectMain}" Value="True">
                                                    <Setter Property="Background" Value="#C8E6C9"/>
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </ListView.ItemContainerStyle>
                                    <ListView.ContextMenu>
                                        <ContextMenu DataContext="{Binding PlacementTarget.Tag, RelativeSource={RelativeSource Self}}">
                                            <MenuItem Header="Export Full Version"       Command="{Binding BackupVM.ExportVersion}"/>
                                            <MenuItem Header="Export Version Log"        Command="{Binding BackupVM.ExtractVersionLog}"/>
                                            <MenuItem Header="Compare With Main"         Command="{Binding BackupVM.CompareDeployedProjectWithMain}"/>
                                            <MenuItem Header="Compare Src With Main"     Command="{Binding FileTrackVM.CompareDeployedProjectWithMain}"/>
                                            <MenuItem Header="Checkout Version"          Command="{Binding BackupVM.CheckoutBackup}"/>
                                            <MenuItem Header="Full Log"                  Command="{Binding BackupVM.ViewFullLog}"/>
                                            <MenuItem Header="Src Full Log"              Command="{Binding FileTrackVM.GetDeployedProjectInfo}"/>
                                            <MenuItem Header="Src Version Similarities"  Command="{Binding FileTrackVM.SrcSimilarityWithBackups}"/>
                                        </ContextMenu>
                                    </ListView.ContextMenu>
                                </ListView>
                            </avalonDockLayout:LayoutAnchorable>
                        </avalonDockLayout:LayoutAnchorablePane>

                        <!-- Diff Log (selected version's changed files) -->
                        <avalonDockLayout:LayoutAnchorablePane DockHeight="0.55*">
                            <avalonDockLayout:LayoutAnchorable Title="Diff Log"
                                                         ContentId="DiffLogPanel"
                                                         CanClose="False"
                                                         CanHide="False">
                                <Grid>
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="*"/>
                                    </Grid.RowDefinitions>
                                    <Grid Grid.Row="0" Margin="2,2,2,0">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="60"/>
                                            <ColumnDefinition Width="*"/>
                                        </Grid.ColumnDefinitions>
                                        <Label  Grid.Column="0" Content="Updater" FontSize="12" Padding="2"/>
                                        <TextBox Grid.Column="1" FontSize="12" Margin="2"
                                                 Text="{Binding BackupVM.UpdaterName}"
                                                 ScrollViewer.HorizontalScrollBarVisibility="Auto"/>
                                    </Grid>
                                    <Grid Grid.Row="1" Margin="2,0,2,2">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="60"/>
                                            <ColumnDefinition Width="*"/>
                                        </Grid.ColumnDefinitions>
                                        <Label  Grid.Column="0" Content="Log" FontSize="12" Padding="2"/>
                                        <TextBox Grid.Column="1" FontSize="12" Margin="2"
                                                 Text="{Binding BackupVM.UpdateLog}"
                                                 TextWrapping="Wrap"
                                                 MaxHeight="50"
                                                 ScrollViewer.HorizontalScrollBarVisibility="Auto"
                                                 ScrollViewer.VerticalScrollBarVisibility="Auto"/>
                                    </Grid>
                                    <DataGrid Grid.Row="2"
                                              x:Name="DiffLog"
                                              ItemsSource="{Binding BackupVM.DiffLog}"
                                              IsReadOnly="True"
                                              BorderBrush="#CDCDCD"
                                              ScrollViewer.CanContentScroll="True"
                                              ScrollViewer.VerticalScrollBarVisibility="Auto"
                                              ScrollViewer.HorizontalScrollBarVisibility="Auto"
                                              CanUserAddRows="False"
                                              CanUserDeleteRows="False"
                                              AutoGenerateColumns="False">
                                        <DataGrid.Columns>
                                            <DataGridTextColumn Header="Filename"  Binding="{Binding DataName}"               Width="2.75*"/>
                                            <DataGridTextColumn Header="Build V"   Binding="{Binding BuildVersion}"           Width="3*"/>
                                            <DataGridTextColumn Header="Project V" Binding="{Binding DeployedProjectVersion}" Width="3*"/>
                                            <DataGridTextColumn Header="Hash"      Binding="{Binding DataHash}"               Width="0.25*"/>
                                            <DataGridTextColumn Header="State"     Binding="{Binding DataState}"              Width="1*"/>
                                            <DataGridTemplateColumn Header="Restore">
                                                <DataGridTemplateColumn.CellTemplate>
                                                    <DataTemplate>
                                                        <Button Content="Restore"
                                                                Command="{Binding DataContext.FileTrackVM.AddForRestore,
                                                                    RelativeSource={RelativeSource AncestorType={x:Type DataGrid}}}"
                                                                CommandParameter="{Binding}"/>
                                                    </DataTemplate>
                                                </DataGridTemplateColumn.CellTemplate>
                                            </DataGridTemplateColumn>
                                        </DataGrid.Columns>
                                        <DataGrid.CellStyle>
                                            <Style TargetType="DataGridCell">
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding IsDstFile}" Value="True">
                                                        <Setter Property="Background">
                                                            <Setter.Value><SolidColorBrush Color="LightGreen" Opacity="0.5"/></Setter.Value>
                                                        </Setter>
                                                    </DataTrigger>
                                                    <DataTrigger Binding="{Binding IsDstFile}" Value="False">
                                                        <Setter Property="Background">
                                                            <Setter.Value><SolidColorBrush Color="LightCoral" Opacity="0.5"/></Setter.Value>
                                                        </Setter>
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </DataGrid.CellStyle>
                                    </DataGrid>
                                </Grid>
                            </avalonDockLayout:LayoutAnchorable>
                        </avalonDockLayout:LayoutAnchorablePane>

                    </avalonDockLayout:LayoutAnchorablePaneGroup>

                    <!-- CENTER: Project Files document tab -->
                    <avalonDockLayout:LayoutDocumentPane>
                        <avalonDockLayout:LayoutDocument Title="Project Files"
                                                   ContentId="ProjectFilesPanel"
                                                   CanClose="False">
                            <Grid>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="40"/>
                                    <RowDefinition Height="*"/>
                                </Grid.RowDefinitions>
                                <TextBox Grid.Row="0"
                                         x:Name="FileFilterKeyword"
                                         TextChanged="FileFilterKeyword_TextChanged"
                                         Height="28"
                                         VerticalAlignment="Center"
                                         Margin="6,4"
                                         FontSize="13"
                                         BorderThickness="1"
                                         BorderBrush="#E0E0E0"/>
                                <DataGrid Grid.Row="1"
                                          x:Name="ProjectMainFileList"
                                          ItemsSource="{Binding MetaDataVM.ProjectFiles}"
                                          IsReadOnly="True"
                                          BorderBrush="#CDCDCD"
                                          ScrollViewer.CanContentScroll="True"
                                          ScrollViewer.VerticalScrollBarVisibility="Auto"
                                          ScrollViewer.HorizontalScrollBarVisibility="Auto"
                                          CanUserAddRows="False"
                                          CanUserDeleteRows="False"
                                          AutoGenerateColumns="False">
                                    <DataGrid.Columns>
                                        <DataGridTextColumn Header="Filename"      Binding="{Binding DataName}"                Width="1*"/>
                                        <DataGridTextColumn Header="Relative Path" Binding="{Binding DataRelPath}"             Width="3*"/>
                                        <DataGridTextColumn Header="Build V"       Binding="{Binding BuildVersion}"            Width="2*"/>
                                        <DataGridTextColumn Header="Deployed V"    Binding="{Binding DeployedProjectVersion}"  Width="1*"/>
                                        <DataGridTextColumn Header="Updated"       Binding="{Binding UpdatedTime}"             Width="2*"/>
                                        <DataGridTextColumn Header="Hash"          Binding="{Binding DataHash}"                Width="1*"/>
                                    </DataGrid.Columns>
                                </DataGrid>
                            </Grid>
                        </avalonDockLayout:LayoutDocument>
                    </avalonDockLayout:LayoutDocumentPane>

                    <!-- RIGHT: Staged Changes (top) + Action Panel (bottom) -->
                    <avalonDockLayout:LayoutAnchorablePaneGroup Orientation="Vertical"
                                                         DockWidth="330">

                        <!-- Staged / Pre-staged changes -->
                        <avalonDockLayout:LayoutAnchorablePane DockHeight="0.6*">
                            <avalonDockLayout:LayoutAnchorable Title="Staged Changes"
                                                         ContentId="StagingPanel"
                                                         CanClose="False"
                                                         CanHide="False">
                                <ListView x:Name="uploadWindow"
                                          ItemsSource="{Binding FileTrackVM.ChangedFileList}"
                                          SelectedItem="{Binding FileTrackVM.SelectedItem, UpdateSourceTrigger=PropertyChanged}"
                                          Tag="{Binding RelativeSource={RelativeSource AncestorType=Window}, Path=DataContext}"
                                          BorderBrush="#CDCDCD"
                                          ScrollViewer.CanContentScroll="True"
                                          ScrollViewer.VerticalScrollBarVisibility="Auto"
                                          ScrollViewer.HorizontalScrollBarVisibility="Auto">
                                    <ListView.View>
                                        <GridView>
                                            <GridViewColumn Header="Name"    DisplayMemberBinding="{Binding DataName}"    Width="80"/>
                                            <GridViewColumn Header="Build V" DisplayMemberBinding="{Binding BuildVersion}" Width="60"/>
                                            <GridViewColumn Header="Path"    DisplayMemberBinding="{Binding DataRelPath}" Width="110"/>
                                            <GridViewColumn Header="State"   DisplayMemberBinding="{Binding DataState}"   Width="70"/>
                                        </GridView>
                                    </ListView.View>
                                    <ListView.ItemContainerStyle>
                                        <Style TargetType="ListViewItem">
                                            <Setter Property="Background" Value="Transparent"/>
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding DataState, Converter={StaticResource DataStateChangeKindConverter}}" Value="Added">
                                                    <Setter Property="Background" Value="#BBDEFB"/>
                                                </DataTrigger>
                                                <DataTrigger Binding="{Binding DataState, Converter={StaticResource DataStateChangeKindConverter}}" Value="Restored">
                                                    <Setter Property="Background" Value="#FFF9C4"/>
                                                </DataTrigger>
                                                <DataTrigger Binding="{Binding DataState, Converter={StaticResource DataStateChangeKindConverter}}" Value="Modified">
                                                    <Setter Property="Background" Value="#C8E6C9"/>
                                                </DataTrigger>
                                                <DataTrigger Binding="{Binding DataState, Converter={StaticResource DataStateChangeKindConverter}}" Value="Deleted">
                                                    <Setter Property="Background" Value="#FFCDD2"/>
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </ListView.ItemContainerStyle>
                                    <ListView.ContextMenu>
                                        <ContextMenu DataContext="{Binding PlacementTarget.Tag, RelativeSource={RelativeSource Self}}">
                                            <MenuItem Header="Revert"
                                                      Command="{Binding FileTrackVM.RevertChange}"/>
                                        </ContextMenu>
                                    </ListView.ContextMenu>
                                </ListView>
                            </avalonDockLayout:LayoutAnchorable>
                        </avalonDockLayout:LayoutAnchorablePane>

                        <!-- Action Panel: updater / log / buttons -->
                        <avalonDockLayout:LayoutAnchorablePane DockHeight="0.4*">
                            <avalonDockLayout:LayoutAnchorable Title="Actions"
                                                         ContentId="ActionPanel"
                                                         CanClose="False"
                                                         CanHide="False">
                                <Grid Margin="6">
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="*"/>
                                    </Grid.RowDefinitions>

                                    <!-- Updater name -->
                                    <Grid Grid.Row="0" Margin="0,2">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="70"/>
                                            <ColumnDefinition Width="*"/>
                                        </Grid.ColumnDefinitions>
                                        <Label  Grid.Column="0" Content="Updater" FontSize="13" Padding="2"/>
                                        <TextBox Grid.Column="1" FontSize="13"
                                                 Text="{Binding MetaDataVM.UpdaterName}"
                                                 ScrollViewer.HorizontalScrollBarVisibility="Auto"/>
                                    </Grid>

                                    <!-- Update log -->
                                    <Grid Grid.Row="1" Margin="0,2">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="70"/>
                                            <ColumnDefinition Width="*"/>
                                        </Grid.ColumnDefinitions>
                                        <Label  Grid.Column="0" Content="Log" FontSize="13" Padding="2"/>
                                        <TextBox Grid.Column="1" FontSize="13"
                                                 TextWrapping="Wrap"
                                                 AcceptsReturn="True"
                                                 Text="{Binding MetaDataVM.UpdateLog}"
                                                 MaxHeight="52"
                                                 ScrollViewer.HorizontalScrollBarVisibility="Auto"
                                                 ScrollViewer.VerticalScrollBarVisibility="Auto"/>
                                    </Grid>

                                    <!-- Action buttons -->
                                    <UniformGrid Grid.Row="2" Columns="2" Margin="0,4,0,0">
                                        <Button Content="Clear"
                                                Margin="2" Height="30" FontSize="13"
                                                Command="{Binding FileTrackVM.ClearNewfiles}"
                                                Style="{StaticResource ActionButtonStyle}"/>
                                        <Button Content="Refresh"
                                                Margin="2" Height="30" FontSize="13"
                                                Command="{Binding FileTrackVM.RefreshDeployFileList}"
                                                Style="{StaticResource ActionButtonStyle}"/>
                                        <Button Content="Stage"
                                                Margin="2" Height="30" FontSize="13"
                                                Command="{Binding FileTrackVM.StageChanges}"
                                                Style="{StaticResource ActionButtonStyle}"/>
                                        <Button Content="Deploy"
                                                Margin="2" Height="30" FontSize="13"
                                                Command="{Binding MetaDataVM.ConductUpdate}"
                                                Style="{StaticResource DeployButtonStyle}"/>
                                    </UniformGrid>

                                </Grid>
                            </avalonDockLayout:LayoutAnchorable>
                        </avalonDockLayout:LayoutAnchorablePane>

                    </avalonDockLayout:LayoutAnchorablePaneGroup>

                </avalonDockLayout:LayoutPanel>
            </avalonDockLayout:LayoutRoot>
        </avalonDock:DockingManager>

    </Grid>
</Window>
