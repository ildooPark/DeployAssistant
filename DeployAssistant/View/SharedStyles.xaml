<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
                    xmlns:conv="clr-namespace:DeployAssistant.View">

    <!-- ═══════════════════════════════════════
         Converters
    ═══════════════════════════════════════════ -->
    <conv:DataStateChangeKindConverter x:Key="DataStateChangeKindConverter"/>

    <!-- ═══════════════════════════════════════
         Colour palette (single source of truth)
    ═══════════════════════════════════════════ -->
    <Color x:Key="ColToolbarBg">#2D2D2D</Color>
    <Color x:Key="ColToolbarBtnBg">#3E3E3E</Color>
    <Color x:Key="ColToolbarBtnHover">#505050</Color>
    <Color x:Key="ColToolbarBtnPressed">#2A7CBB</Color>
    <Color x:Key="ColActionBtnBg">#E0E0E0</Color>
    <Color x:Key="ColActionBtnHover">#BDBDBD</Color>
    <Color x:Key="ColActionBtnPressed">#9E9E9E</Color>
    <Color x:Key="ColDeployBtnBg">#388E3C</Color>
    <Color x:Key="ColDeployBtnHover">#2E7D32</Color>
    <Color x:Key="ColDeployBtnPressed">#1B5E20</Color>

    <!-- diff-row semantic tints (matches MainWindow badge palette) -->
    <Color x:Key="ColAdded">#C8E6C9</Color>       <!-- green  -->
    <Color x:Key="ColModified">#FFF9C4</Color>    <!-- amber  -->
    <Color x:Key="ColDeleted">#FFCDD2</Color>     <!-- red    -->
    <Color x:Key="ColRestored">#BBDEFB</Color>    <!-- blue   -->
    <Color x:Key="ColMatchExact">#A5D6A7</Color>  <!-- strong green for exact match -->

    <SolidColorBrush x:Key="BrAdded"     Color="{StaticResource ColAdded}"/>
    <SolidColorBrush x:Key="BrModified"  Color="{StaticResource ColModified}"/>
    <SolidColorBrush x:Key="BrDeleted"   Color="{StaticResource ColDeleted}"/>
    <SolidColorBrush x:Key="BrRestored"  Color="{StaticResource ColRestored}"/>
    <SolidColorBrush x:Key="BrMatchExact" Color="{StaticResource ColMatchExact}"/>

    <!-- pill label colours -->
    <SolidColorBrush x:Key="BrPillAdded"    Color="#388E3C"/>
    <SolidColorBrush x:Key="BrPillModified" Color="#F57F17"/>
    <SolidColorBrush x:Key="BrPillDeleted"  Color="#C62828"/>

    <!-- ═══════════════════════════════════════
         ToolbarButtonStyle  (dark toolbar)
    ═══════════════════════════════════════════ -->
    <Style x:Key="ToolbarButtonStyle" TargetType="Button">
        <Setter Property="Background"   Value="#3E3E3E"/>
        <Setter Property="Foreground"   Value="White"/>
        <Setter Property="BorderBrush"  Value="#555555"/>
        <Setter Property="BorderThickness" Value="1"/>
        <Setter Property="Cursor"       Value="Hand"/>
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="Button">
                    <Border Background="{TemplateBinding Background}"
                            BorderBrush="{TemplateBinding BorderBrush}"
                            BorderThickness="{TemplateBinding BorderThickness}"
                            CornerRadius="3"
                            Padding="{TemplateBinding Padding}">
                        <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                    </Border>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter Property="Background" Value="#505050"/>
                        </Trigger>
                        <Trigger Property="IsPressed" Value="True">
                            <Setter Property="Background" Value="#2A7CBB"/>
                        </Trigger>
                        <Trigger Property="IsEnabled" Value="False">
                            <Setter Property="Opacity" Value="0.4"/>
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <!-- ═══════════════════════════════════════
         ActionButtonStyle  (light panel buttons)
    ═══════════════════════════════════════════ -->
    <Style x:Key="ActionButtonStyle" TargetType="Button">
        <Setter Property="Background"      Value="#E0E0E0"/>
        <Setter Property="Foreground"      Value="#212121"/>
        <Setter Property="BorderBrush"     Value="#BDBDBD"/>
        <Setter Property="BorderThickness" Value="1"/>
        <Setter Property="Cursor"          Value="Hand"/>
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="Button">
                    <Border Background="{TemplateBinding Background}"
                            BorderBrush="{TemplateBinding BorderBrush}"
                            BorderThickness="{TemplateBinding BorderThickness}"
                            CornerRadius="3"
                            Padding="{TemplateBinding Padding}">
                        <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                    </Border>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter Property="Background" Value="#BDBDBD"/>
                        </Trigger>
                        <Trigger Property="IsPressed" Value="True">
                            <Setter Property="Background" Value="#9E9E9E"/>
                        </Trigger>
                        <Trigger Property="IsEnabled" Value="False">
                            <Setter Property="Opacity" Value="0.4"/>
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <!-- ═══════════════════════════════════════
         DeployButtonStyle  (green confirm)
    ═══════════════════════════════════════════ -->
    <Style x:Key="DeployButtonStyle" TargetType="Button" BasedOn="{StaticResource ActionButtonStyle}">
        <Setter Property="Background" Value="#388E3C"/>
        <Setter Property="Foreground" Value="White"/>
        <Style.Triggers>
            <Trigger Property="IsMouseOver" Value="True">
                <Setter Property="Background" Value="#2E7D32"/>
            </Trigger>
            <Trigger Property="IsPressed" Value="True">
                <Setter Property="Background" Value="#1B5E20"/>
            </Trigger>
        </Style.Triggers>
    </Style>

    <!-- ═══════════════════════════════════════
         DiffRowStyle  — ListViewItem / DataGridRow
         Added=green, Modified=amber, Deleted=red
    ═══════════════════════════════════════════ -->
    <Style x:Key="DiffRowStyle" TargetType="ListViewItem">
        <Setter Property="Background" Value="Transparent"/>
        <Style.Triggers>
            <DataTrigger Binding="{Binding DataState, Converter={StaticResource DataStateChangeKindConverter}}" Value="Added">
                <Setter Property="Background" Value="{StaticResource BrAdded}"/>
            </DataTrigger>
            <DataTrigger Binding="{Binding DataState, Converter={StaticResource DataStateChangeKindConverter}}" Value="Modified">
                <Setter Property="Background" Value="{StaticResource BrModified}"/>
            </DataTrigger>
            <DataTrigger Binding="{Binding DataState, Converter={StaticResource DataStateChangeKindConverter}}" Value="Deleted">
                <Setter Property="Background" Value="{StaticResource BrDeleted}"/>
            </DataTrigger>
            <DataTrigger Binding="{Binding DataState, Converter={StaticResource DataStateChangeKindConverter}}" Value="Restored">
                <Setter Property="Background" Value="{StaticResource BrRestored}"/>
            </DataTrigger>
        </Style.Triggers>
    </Style>

    <!-- ═══════════════════════════════════════
         PillTextStyle  — state pill label
    ═══════════════════════════════════════════ -->
    <Style x:Key="PillTextStyle" TargetType="TextBlock">
        <Setter Property="FontSize"     Value="11"/>
        <Setter Property="FontWeight"   Value="Bold"/>
        <Setter Property="Foreground"   Value="White"/>
        <Setter Property="HorizontalAlignment" Value="Center"/>
        <Setter Property="VerticalAlignment"   Value="Center"/>
        <Setter Property="Margin"       Value="0"/>
    </Style>

    <!-- ═══════════════════════════════════════
         FilterBoxStyle  — standard filter TextBox
    ═══════════════════════════════════════════ -->
    <Style x:Key="FilterBoxStyle" TargetType="TextBox">
        <Setter Property="Height"           Value="28"/>
        <Setter Property="VerticalAlignment" Value="Center"/>
        <Setter Property="FontSize"         Value="13"/>
        <Setter Property="BorderThickness"  Value="1"/>
        <Setter Property="BorderBrush"      Value="#E0E0E0"/>
        <Setter Property="Padding"          Value="4,2"/>
    </Style>

    <!-- placeholder adorner style for TextBox -->
    <Style x:Key="PlaceholderStyle" TargetType="TextBlock">
        <Setter Property="Foreground"       Value="#AAAAAA"/>
        <Setter Property="FontSize"         Value="13"/>
        <Setter Property="VerticalAlignment" Value="Center"/>
        <Setter Property="Margin"           Value="6,0"/>
        <Setter Property="IsHitTestVisible" Value="False"/>
    </Style>

    <!-- ═══════════════════════════════════════
         HeaderLabelStyle  — section label above lists
    ═══════════════════════════════════════════ -->
    <Style x:Key="HeaderLabelStyle" TargetType="TextBlock">
        <Setter Property="FontSize"   Value="12"/>
        <Setter Property="FontWeight" Value="SemiBold"/>
        <Setter Property="Foreground" Value="#444444"/>
        <Setter Property="Margin"     Value="4,4,4,2"/>
    </Style>

</ResourceDictionary>
