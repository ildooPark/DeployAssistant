<Window x:Class="DeployAssistant.View.VersionComparisonWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:DeployAssistant.View"
        mc:Ignorable="d"
        Title="Version Compatibility"
        Height="560" Width="940"
        MinHeight="400" MinWidth="700"
        WindowStartupLocation="CenterOwner"
        ShowInTaskbar="False">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- ── Header banner ── -->
        <Border Grid.Row="0" Background="#2D2D2D" Padding="10,6">
            <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                <TextBlock Foreground="#BBBBBB" FontSize="13" VerticalAlignment="Center">
                    <Run Text="Source: "/>
                    <Run Text="{Binding SrcProjVersion, FallbackValue='—'}"
                         FontWeight="Bold" Foreground="#4EC9B0"/>
                </TextBlock>
                <TextBlock Foreground="#777777" FontSize="13" Margin="16,0" VerticalAlignment="Center" Text="·"/>
                <TextBlock Foreground="#BBBBBB" FontSize="13" VerticalAlignment="Center">
                    <Run Text="PC: "/>
                    <Run Text="{Binding SrcProjConductedPC, FallbackValue='—'}"
                         FontWeight="Bold" Foreground="White"/>
                </TextBlock>
            </StackPanel>
        </Border>

        <!-- ── Two-panel body ── -->
        <Grid Grid.Row="1">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="4*"/>
                <ColumnDefinition Width="6*"/>
            </Grid.ColumnDefinitions>

            <!-- Left: version similarity list -->
            <Grid Grid.Column="0">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>
                <TextBlock Grid.Row="0" Style="{StaticResource HeaderLabelStyle}"
                           Text="Snapshot history — select a version to inspect its diff"/>
                <ListView Grid.Row="1"
                          x:Name="LocalProjectVersions"
                          ItemsSource="{Binding VersionSimilarities}"
                          SelectedItem="{Binding Selected}"
                          BorderBrush="#CDCDCD"
                          ScrollViewer.CanContentScroll="True"
                          ScrollViewer.VerticalScrollBarVisibility="Auto"
                          ScrollViewer.HorizontalScrollBarVisibility="Auto">
                    <ListView.View>
                        <GridView>
                            <GridViewColumn Width="220">
                                <GridViewColumn.Header>
                                    <TextBlock Text="Version"/>
                                </GridViewColumn.Header>
                                <GridViewColumn.CellTemplate>
                                    <DataTemplate>
                                        <TextBlock Text="{Binding projData.UpdatedVersion}"
                                                   TextTrimming="CharacterEllipsis" MaxWidth="215"/>
                                    </DataTemplate>
                                </GridViewColumn.CellTemplate>
                            </GridViewColumn>
                            <GridViewColumn Width="55">
                                <GridViewColumn.Header>
                                    <TextBlock Text="Δ Sig."
                                               ToolTip="Significant differences: files outside the integration-ignore list (en-US, ko-KR, Resources…).&#10;0 = source is an exact functional match for this snapshot."/>
                                </GridViewColumn.Header>
                                <GridViewColumn.CellTemplate>
                                    <DataTemplate>
                                        <TextBlock Text="{Binding numDiffWithoutResources}"
                                                   HorizontalAlignment="Center"
                                                   FontWeight="SemiBold">
                                            <TextBlock.Style>
                                                <Style TargetType="TextBlock">
                                                    <Setter Property="Foreground" Value="#333333"/>
                                                    <Style.Triggers>
                                                        <DataTrigger Binding="{Binding numDiffWithoutResources}" Value="0">
                                                            <Setter Property="Foreground" Value="#388E3C"/>
                                                        </DataTrigger>
                                                    </Style.Triggers>
                                                </Style>
                                            </TextBlock.Style>
                                        </TextBlock>
                                    </DataTemplate>
                                </GridViewColumn.CellTemplate>
                            </GridViewColumn>
                            <GridViewColumn Width="65">
                                <GridViewColumn.Header>
                                    <TextBlock Text="Δ Resource"
                                               ToolTip="Total differences including resource-only files (en-US, ko-KR, Resources).&#10;Equals Δ Sig. when there are no resource-only changes."/>
                                </GridViewColumn.Header>
                                <GridViewColumn.CellTemplate>
                                    <DataTemplate>
                                        <TextBlock Text="{Binding numDiffWithResources}"
                                                   HorizontalAlignment="Center"/>
                                    </DataTemplate>
                                </GridViewColumn.CellTemplate>
                            </GridViewColumn>
                        </GridView>
                    </ListView.View>

                    <ListView.ItemContainerStyle>
                        <Style TargetType="ListViewItem">
                            <Setter Property="Background" Value="Transparent"/>
                            <Style.Triggers>
                                <!-- Exact functional match — highlight green like "clean working tree" -->
                                <DataTrigger Binding="{Binding numDiffWithoutResources}" Value="0">
                                    <Setter Property="Background" Value="{StaticResource BrMatchExact}"/>
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </ListView.ItemContainerStyle>
                </ListView>
            </Grid>

            <!-- Right: diff detail for selected version -->
            <Grid Grid.Column="1">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>
                <TextBlock Grid.Row="0" Style="{StaticResource HeaderLabelStyle}">
                    <Run Text="Selected: "/>
                    <Run Text="{Binding TargetProjVersion, FallbackValue='—'}"
                         FontWeight="Bold" Foreground="#1976D2"/>
                </TextBlock>
                <ListView Grid.Row="1"
                          x:Name="DiffItemsList"
                          ItemsSource="{Binding FileDifferences}"
                          BorderBrush="#CDCDCD"
                          ScrollViewer.CanContentScroll="True"
                          ScrollViewer.VerticalScrollBarVisibility="Auto"
                          ScrollViewer.HorizontalScrollBarVisibility="Auto">
                    <ListView.View>
                        <GridView>
                            <!-- state pill -->
                            <GridViewColumn Header="" Width="32">
                                <GridViewColumn.CellTemplate>
                                    <DataTemplate>
                                        <Border CornerRadius="3" Padding="3,1" Margin="1">
                                            <Border.Style>
                                                <Style TargetType="Border">
                                                    <Setter Property="Background" Value="#9E9E9E"/>
                                                    <Style.Triggers>
                                                        <DataTrigger Binding="{Binding DataState, Converter={StaticResource DataStateChangeKindConverter}}" Value="Added">
                                                            <Setter Property="Background" Value="{StaticResource BrPillAdded}"/>
                                                        </DataTrigger>
                                                        <DataTrigger Binding="{Binding DataState, Converter={StaticResource DataStateChangeKindConverter}}" Value="Modified">
                                                            <Setter Property="Background" Value="{StaticResource BrPillModified}"/>
                                                        </DataTrigger>
                                                        <DataTrigger Binding="{Binding DataState, Converter={StaticResource DataStateChangeKindConverter}}" Value="Deleted">
                                                            <Setter Property="Background" Value="{StaticResource BrPillDeleted}"/>
                                                        </DataTrigger>
                                                    </Style.Triggers>
                                                </Style>
                                            </Border.Style>
                                            <TextBlock>
                                                <TextBlock.Style>
                                                    <Style TargetType="TextBlock" BasedOn="{StaticResource PillTextStyle}">
                                                        <Setter Property="Text" Value="?"/>
                                                        <Style.Triggers>
                                                            <DataTrigger Binding="{Binding DataState, Converter={StaticResource DataStateChangeKindConverter}}" Value="Added">
                                                                <Setter Property="Text" Value="+"/>
                                                            </DataTrigger>
                                                            <DataTrigger Binding="{Binding DataState, Converter={StaticResource DataStateChangeKindConverter}}" Value="Modified">
                                                                <Setter Property="Text" Value="~"/>
                                                            </DataTrigger>
                                                            <DataTrigger Binding="{Binding DataState, Converter={StaticResource DataStateChangeKindConverter}}" Value="Deleted">
                                                                <Setter Property="Text" Value="−"/>
                                                            </DataTrigger>
                                                        </Style.Triggers>
                                                    </Style>
                                                </TextBlock.Style>
                                            </TextBlock>
                                        </Border>
                                    </DataTemplate>
                                </GridViewColumn.CellTemplate>
                            </GridViewColumn>
                            <GridViewColumn Header="Source File"
                                            DisplayMemberBinding="{Binding SrcFile.DataRelPath}"
                                            Width="155"/>
                            <GridViewColumn Header="Src Build V"
                                            DisplayMemberBinding="{Binding SrcFile.BuildVersion}"
                                            Width="110"/>
                            <GridViewColumn Header="Destination File"
                                            DisplayMemberBinding="{Binding DstFile.DataRelPath}"
                                            Width="155"/>
                            <GridViewColumn Header="Dst Build V"
                                            DisplayMemberBinding="{Binding DstFile.BuildVersion}"
                                            Width="110"/>
                        </GridView>
                    </ListView.View>

                    <ListView.ItemContainerStyle>
                        <Style TargetType="ListViewItem" BasedOn="{StaticResource DiffRowStyle}"/>
                    </ListView.ItemContainerStyle>
                </ListView>
            </Grid>
        </Grid>
    </Grid>
</Window>
